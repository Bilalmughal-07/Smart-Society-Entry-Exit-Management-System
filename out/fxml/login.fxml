<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.smartsociety.ui.LoginUIController"
           prefWidth="480" prefHeight="580" styleClass="root">

    <VBox alignment="CENTER" maxWidth="360">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <VBox fx:id="loginCard" styleClass="login-card" spacing="18">

            <!-- App icon + branding -->
            <VBox alignment="CENTER" spacing="10">
                <StackPane styleClass="avatar-circle" prefWidth="56" prefHeight="56" alignment="CENTER">
                    <Label text="🏠" style="-fx-font-size: 26px;"/>
                </StackPane>
                <Label text="Smart Society" styleClass="title-label"/>
                <Label text="Entry Management System" styleClass="subtitle-label"/>
            </VBox>

            <Separator/>

            <!-- Form fields -->
            <VBox spacing="12">
                <Label text="USERNAME" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="Enter your username"/>

                <Label text="PASSWORD" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password"/>
            </VBox>

            <!-- Status -->
            <Label fx:id="statusLabel" text="" wrapText="true"/>

            <!-- Sign In -->
            <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin"
                    maxWidth="Infinity" prefHeight="44"/>

            <!-- Hint -->
            <VBox alignment="CENTER" spacing="3">
                <Label text="Default credentials" style="-fx-text-fill: rgba(255,255,255,0.22); -fx-font-size: 11px;"/>
                <Label text="admin / guard1 / resident1  •  password123"
                       style="-fx-text-fill: rgba(255,255,255,0.16); -fx-font-size: 11px;"/>
            </VBox>
        </VBox>
    </VBox>
</StackPane>
