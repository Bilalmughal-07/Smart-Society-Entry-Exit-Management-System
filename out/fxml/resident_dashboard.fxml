<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.smartsociety.ui.ResidentDashboardController"
           styleClass="root liquid-root dashboard-root">

    <Pane fx:id="ambientLayer" mouseTransparent="true" styleClass="ambient-layer">
        <effect>
            <GaussianBlur radius="3.2"/>
        </effect>
        <Circle radius="225" centerX="155" centerY="135" styleClass="ambient-orb ambient-orb-a"/>
        <Circle radius="260" centerX="1040" centerY="640" styleClass="ambient-orb ambient-orb-b"/>
        <Rectangle width="375" height="150" x="680" y="45" arcWidth="88" arcHeight="88"
                   rotate="-13" styleClass="ambient-slab ambient-slab-a"/>
        <Rectangle width="300" height="120" x="-65" y="540" arcWidth="78" arcHeight="78"
                   rotate="20" styleClass="ambient-slab ambient-slab-b"/>
    </Pane>
    <Pane mouseTransparent="true" styleClass="ambient-frost"/>

    <BorderPane styleClass="app-shell">

    <!-- ═══ Sidebar ═══ -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" minWidth="200">

            <!-- User area -->
            <VBox styleClass="sidebar-user">
                <StackPane styleClass="avatar-circle" prefWidth="48" prefHeight="48" alignment="CENTER">
                    <Label fx:id="avatarLabel" text="R" styleClass="avatar-label"/>
                </StackPane>
                <Label fx:id="welcomeLabel" text="" styleClass="sidebar-username"/>
                <Label text="Resident" styleClass="sidebar-role"/>
                <Button fx:id="notifBadge" text="🔔 0" styleClass="notif-badge-btn"
                        onAction="#showNotifications"/>
            </VBox>

            <!-- Navigation -->
            <VBox styleClass="sidebar-nav" VBox.vgrow="ALWAYS">
                <Button fx:id="navBtn0" text="📋  Create Approval" onAction="#showSection0"
                        styleClass="sidebar-item sidebar-item-active" maxWidth="Infinity"/>
                <Button fx:id="navBtn1" text="📑  My Approvals" onAction="#showSection1"
                        styleClass="sidebar-item" maxWidth="Infinity"/>
                <Button fx:id="navBtn2" text="🚪  Arrival Requests" onAction="#showSection2"
                        styleClass="sidebar-item" maxWidth="Infinity"/>
                <Button fx:id="navBtn3" text="🔔  Notifications" onAction="#showSection3"
                        styleClass="sidebar-item" maxWidth="Infinity"/>
                <Button fx:id="navBtn4" text="📜  Access Rules" onAction="#showSection4"
                        styleClass="sidebar-item" maxWidth="Infinity"/>
                <Button fx:id="navBtn5" text="QR Code" onAction="#showSection5"
                        styleClass="sidebar-item" maxWidth="Infinity"/>
            </VBox>

            <!-- Sign Out -->
            <VBox styleClass="sidebar-footer">
                <Button text="Sign Out" onAction="#handleLogout" styleClass="sidebar-logout" maxWidth="Infinity"/>
                <Button text="Exit App" onAction="#handleExitApp" styleClass="sidebar-logout sidebar-exit" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <!-- ═══ Content Area ═══ -->
    <center>
        <StackPane styleClass="content-area">

            <!-- Section 0: Create Approval -->
            <ScrollPane fx:id="section0" fitToWidth="true" visible="true" managed="true"
                        maxWidth="Infinity" maxHeight="Infinity">
                <VBox spacing="16" maxWidth="Infinity">
                    <Label text="Pre-Approve a Visitor" styleClass="section-label"/>

                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="VISITOR NAME *" styleClass="field-label"/>
                            <TextField fx:id="visitorNameField" promptText="Full name"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="CONTACT" styleClass="field-label"/>
                            <TextField fx:id="visitorContactField" promptText="Phone number"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="CATEGORY *" styleClass="field-label"/>
                            <ComboBox fx:id="categoryCombo" maxWidth="Infinity" promptText="Select category"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="PURPOSE" styleClass="field-label"/>
                            <TextField fx:id="purposeField" promptText="Reason for visit"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="VISIT DATE *" styleClass="field-label"/>
                            <DatePicker fx:id="visitDatePicker" maxWidth="Infinity"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="DURATION (MINUTES)" styleClass="field-label"/>
                            <TextField fx:id="durationField" promptText="60" text="60"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="ARRIVAL TIME *" styleClass="field-label"/>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <TextField fx:id="timeHourField" promptText="HH" prefWidth="64"/>
                                <Label text=":" style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 16px;"/>
                                <TextField fx:id="timeMinField" promptText="MM" prefWidth="64"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="EXIT TIME (AUTO)" styleClass="field-label"/>
                            <TextField fx:id="timeEndField" editable="false" promptText="--:--"
                                       style="-fx-opacity: 0.5;"/>
                        </VBox>
                    </HBox>

                    <Label fx:id="approvalStatusLabel" text="" wrapText="true"/>

                    <HBox spacing="10">
                        <Button text="Create Approval" onAction="#handleCreateApproval" styleClass="button-success"/>
                        <Button text="Clear" onAction="#handleClear" styleClass="button-secondary"/>
                    </HBox>

                    <!-- QR Code Display -->
                    <VBox fx:id="qrDisplayBox" spacing="10" alignment="CENTER"
                          visible="false" managed="false">
                        <Separator/>
                        <Label text="QR Code Generated" styleClass="success-label"/>
                        <StackPane styleClass="qr-container" prefWidth="182" prefHeight="182" alignment="CENTER">
                            <ImageView fx:id="qrImageView" fitWidth="150" fitHeight="150" preserveRatio="true"/>
                        </StackPane>
                        <Label fx:id="qrCodeLabel" text=""
                               style="-fx-font-size: 13px; -fx-text-fill: #4DAAFF; -fx-font-family: monospace;"/>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Section 1: My Approvals -->
            <VBox fx:id="section1" spacing="16" visible="false" managed="false"
                  maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Your Visitor Approvals" styleClass="section-label" HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh" onAction="#loadApprovals" styleClass="button-secondary"/>
                </HBox>
                <TableView fx:id="approvalsTable" VBox.vgrow="ALWAYS" maxWidth="Infinity">
                    <columns>
                        <TableColumn fx:id="colVisitor" text="Visitor" prefWidth="120"/>
                        <TableColumn fx:id="colCategory" text="Category" prefWidth="80"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="90"/>
                        <TableColumn fx:id="colTime" text="Time Window" prefWidth="110"/>
                        <TableColumn fx:id="colQR" text="QR Code" prefWidth="140"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
                    </columns>
                </TableView>
                <HBox spacing="10">
                    <Button text="Cancel Selected" onAction="#handleCancelApproval" styleClass="button-danger"/>
                </HBox>
            </VBox>

            <!-- Section 2: Arrival Requests -->
            <VBox fx:id="section2" spacing="16" visible="false" managed="false"
                  maxWidth="Infinity" maxHeight="Infinity">
                <Label text="Pending Visitor Arrival Requests" styleClass="section-label"/>
                <TableView fx:id="arrivalRequestsTable" VBox.vgrow="ALWAYS" maxWidth="Infinity">
                    <columns>
                        <TableColumn fx:id="colArrVisitor" text="Visitor" prefWidth="120"/>
                        <TableColumn fx:id="colArrContact" text="Contact" prefWidth="110"/>
                        <TableColumn fx:id="colArrPurpose" text="Purpose" prefWidth="140"/>
                        <TableColumn fx:id="colArrGuard" text="Guard" prefWidth="100"/>
                        <TableColumn fx:id="colArrTime" text="Time" prefWidth="140"/>
                    </columns>
                </TableView>
                <HBox spacing="10">
                    <Button text="Approve" onAction="#handleApproveArrival" styleClass="button-success"/>
                    <Button text="Reject" onAction="#handleRejectArrival" styleClass="button-danger"/>
                    <Button text="Refresh" onAction="#loadArrivalRequests" styleClass="button-secondary"/>
                </HBox>
            </VBox>

            <!-- Section 3: Notifications -->
            <VBox fx:id="section3" spacing="16" visible="false" managed="false"
                  maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Notifications" styleClass="section-label" HBox.hgrow="ALWAYS"/>
                    <Button text="Mark All Read" onAction="#markAllRead" styleClass="button-secondary"/>
                    <Button text="Refresh" onAction="#loadNotifications" styleClass="button-secondary"/>
                </HBox>
                <ListView fx:id="notificationsList" VBox.vgrow="ALWAYS" maxWidth="Infinity"/>
            </VBox>

            <!-- Section 4: Access Rules -->
            <VBox fx:id="section4" spacing="16" visible="false" managed="false"
                  maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Admin Visitor Rules" styleClass="section-label" HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh" onAction="#loadRules" styleClass="button-secondary"/>
                </HBox>
                <Label text="Check these rules before scheduling visitors to avoid rejection."
                       style="-fx-text-fill: rgba(255,255,255,0.40); -fx-font-size: 12px;"/>
                <TableView fx:id="rulesTable" VBox.vgrow="ALWAYS" maxWidth="Infinity">
                    <columns>
                        <TableColumn fx:id="colRuleName" text="Rule Name" prefWidth="120"/>
                        <TableColumn fx:id="colRuleCat" text="Category" prefWidth="90"/>
                        <TableColumn fx:id="colRuleTime" text="Allowed Time" prefWidth="120"/>
                        <TableColumn fx:id="colRuleDuration" text="Max Duration" prefWidth="90"/>
                        <TableColumn fx:id="colRuleVisitors" text="Max Visitors/Day" prefWidth="110"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Section 5: Resident QR Code -->
            <VBox fx:id="section5" spacing="16" visible="false" managed="false"
                  maxWidth="Infinity" maxHeight="Infinity" alignment="CENTER">
                <Label text="Resident Gate QR" styleClass="section-label"/>
                <StackPane styleClass="qr-container" prefWidth="260" prefHeight="260" alignment="CENTER">
                    <ImageView fx:id="residentQrImageView" fitWidth="220" fitHeight="220" preserveRatio="true"/>
                </StackPane>
                <Label fx:id="residentQrCodeLabel" text=""
                       style="-fx-font-size: 14px; -fx-text-fill: #4DAAFF; -fx-font-family: monospace;"/>
                <Label fx:id="residentQrStatusLabel" text="" wrapText="true"/>
                <Button text="Refresh" onAction="#loadResidentQR" styleClass="button-secondary"/>
            </VBox>

        </StackPane>
    </center>
    </BorderPane>
</StackPane>
